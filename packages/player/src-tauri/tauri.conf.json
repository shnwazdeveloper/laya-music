{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Laya Music",
  "mainBinaryName": "laya-music",
  "version": "1.39.0",
  "identifier": "com.layamusic.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "cd ../.. && pnpm --filter @nuclearplayer/player build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Laya Music",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Music",
    "shortDescription": "Music streaming app for your desktop",
    "longDescription": "Laya Music is a desktop music player powered by YouTube Music search and YouTube audio streaming.",
    "copyright": "Copyright 2026 SHNWAZ Developer",
    "homepage": "https://github.com/shnwazdeveloper/laya-music",
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      },
      "rpm": {
        "epoch": 0,
        "files": {},
        "release": "1"
      }
    },
    "macOS": {
      "signingIdentity": "-",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczRDk0QzBFODNCNDEyNUUKUldSZUVyU0REa3paYzdTaE9IdlErcjNoTmdyMkNLL0d3alFZTHVMcytxQzJ3K1NJRlFWQlVaYk4K",
      "endpoints": [
        "https://github.com/shnwazdeveloper/laya-music/releases/latest/download/latest.json"
      ]
    }
  }
}
